# Copy this file to ".env" and fill in your Supabase project values.
# Find them in your Supabase dashboard under: Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Use your project's publishable key (sb_publishable_...). The older "anon" key
# also works if you set VITE_SUPABASE_ANON_KEY instead.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
